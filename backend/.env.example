# put your mongodb url here
# get this from atlas or use localhost:27017/vpms
MONGO_URI=

# make this something secret and long, doesn't matter what it is
JWT_SECRET=

# how long tokens last
JWT_EXPIRES_IN=7d

# your frontend url - change this in production
CLIENT_URL=http://localhost:5173

# cloudinary - sign up at cloudinary.com, its free
# you need this for photo uploads and pdf storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# email - use a gmail with app passwords enabled
# go to google account > security > app passwords to get this
EMAIL_USER=
EMAIL_PASS=

# twilio for sms - optional, app works without it
# sign up at twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

PORT=5000
